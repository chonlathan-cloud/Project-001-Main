# App
APP_ENV: "production"
APP_HOST: "0.0.0.0"
APP_PORT: "8000"
APP_DEBUG: "false"
CORS_ORIGINS: "https://your-frontend-cloud-run-url"
LINE_REDIRECT_URI: "https://your-frontend-cloud-run-url/auth/line/callback"

# Database
# Prefer Secret Manager via BACKEND_SECRET_ENV_VARS in cloudrun.env.
# DATABASE_URL: "postgresql+asyncpg://USER:PASSWORD@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE"

# GCP / Firebase
GCP_PROJECT_ID: "your-gcp-project-id"
GCP_LOCATION: "asia-southeast1"
FIREBASE_PROJECT_ID: "your-firebase-project-id"
FIRESTORE_DATABASE_ID: "(default)"
IDENTITY_PLATFORM_TENANT_ID: ""
GOOGLE_APPLICATION_CREDENTIALS: ""
FIREBASE_WEB_API_KEY: "your-firebase-web-api-key"
FIREBASE_AUTH_EMULATOR_HOST: ""
FIREBASE_STORAGE_BUCKET: "your-firebase-storage-bucket"

# LINE Login / LIFF
LINE_CHANNEL_ID: "your-line-channel-id"
# Prefer Secret Manager for LINE_CHANNEL_SECRET.
# LINE_CHANNEL_SECRET: "your-line-channel-secret"
LINE_LIFF_ID: "your-line-liff-id"

# JWT / Session
# Prefer Secret Manager for JWT_SECRET_KEY.
# JWT_SECRET_KEY: "replace-me"
JWT_ALGORITHM: "HS256"
JWT_EXPIRE_MINUTES: "480"

# GCS
GCS_BUCKET_NAME: "your-private-storage-bucket"
GCS_KYC_PREFIX: "kyc_id_cards"
GCS_PROFILE_PREFIX: "profile_images"
GCS_TEMP_BILLS_PREFIX: "temp_bills"
GCS_PERM_BILLS_PREFIX: "perm_bills"
SIGNED_URL_EXPIRES_MINUTES: "15"
INSPECTION_GCS_BUCKET: "your-inspection-bucket"
INSPECTION_GCS_PREFIX: "inspection"
INSPECTION_PHOTO_MAX_BYTES: "10485760"
INSPECTION_PLAN_MAX_BYTES: "26214400"

# AI
GEMINI_MODEL: "gemini-2.5-flash"
EMBEDDING_MODEL: "text-embedding-004"
BOQ_BATCH_SYNC_MAX_TABS: "3"

# FlowAccount OpenAPI
FLOWACCOUNT_ENABLED: "false"
FLOWACCOUNT_BASE_URL: "https://openapi.flowaccount.com/test"
# Prefer Secret Manager for FlowAccount credentials.
# FLOWACCOUNT_CLIENT_ID: "your-flowaccount-client-id"
# FLOWACCOUNT_CLIENT_SECRET: "your-flowaccount-client-secret"
FLOWACCOUNT_SCOPE: "flowaccount-api"
FLOWACCOUNT_TOKEN_CACHE_SECONDS: "84000"
FLOWACCOUNT_TIMEOUT_SECONDS: "20"
FLOWACCOUNT_DEFAULT_PAYMENT_METHOD: "transfer"
FLOWACCOUNT_DEFAULT_BANK_ACCOUNT_ID: ""
FLOWACCOUNT_EXPENSE_CATEGORY_MAPPING_JSON: "{}"

# Admin bootstrap
ADMIN_EMAIL_DOMAIN: "yourcompany.com"
ADMIN_EMAILS: ""
