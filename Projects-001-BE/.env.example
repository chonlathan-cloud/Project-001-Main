# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/project-001

# GCP / Firebase
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=asia-southeast1
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_EMULATOR_HOST=
FIREBASE_STORAGE_BUCKET=your-storage-bucket

# LINE Login / LIFF
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_LIFF_ID=your-liff-id
LINE_REDIRECT_URI=http://localhost:5173/auth/line/callback

# JWT / Session
JWT_SECRET_KEY=replace-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# GCS
GCS_BUCKET_NAME=your-storage-bucket
GCS_KYC_PREFIX=kyc_id_cards
GCS_TEMP_BILLS_PREFIX=temp_bills
GCS_PERM_BILLS_PREFIX=perm_bills
SIGNED_URL_EXPIRES_MINUTES=15

# AI
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
BOQ_BATCH_SYNC_MAX_TABS=3

# Admin bootstrap
ADMIN_EMAIL_DOMAIN=yourcompany.com
ADMIN_EMAILS=
